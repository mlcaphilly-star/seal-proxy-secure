{% assign is_coach = false %}
{% if customer and customer.tags contains 'COACH' or customer and customer.tags contains 'Coach' or customer and customer.tags contains 'coach' %}
  {% assign is_coach = true %}
{% endif %}
{% if customer and customer.tags contains 'ADMIN' or customer and customer.tags contains 'Admin' or customer and customer.tags contains 'admin' %}
  {% assign is_coach = true %}
{% endif %}
{% if customer and customer.tags contains 'SUPERUSER' %}
  {% assign is_coach = true %}
{% endif %}

{% if is_coach %}
<section class="assign-batch" style="max-width:1200px;margin:0 auto;padding:2rem;">
  <h1 style="margin:0 0 1rem;">Assign Batch</h1>

  <div style="border:1px solid #ddd;border-radius:6px;padding:1rem;margin-bottom:1rem;">
    <label for="coachKey" style="display:block;font-weight:600;margin-bottom:0.35rem;">Coach Key</label>
    <input id="coachKey" type="password" autocomplete="off" style="width:100%;max-width:420px;padding:0.55rem;border:1px solid #bbb;border-radius:4px;">
    <button id="saveCoachKey" type="button" style="margin-left:0.5rem;padding:0.55rem 0.9rem;border:0;border-radius:4px;background:#111;color:#fff;">Use Key</button>
    <span id="coachKeyStatus" style="margin-left:0.75rem;font-weight:600;"></span>
  </div>

  <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(220px,1fr));gap:0.75rem;margin-bottom:1rem;">
    <div>
      <label for="assignParticipantName" style="display:block;font-weight:600;margin-bottom:0.35rem;">Participant Name</label>
      <input id="assignParticipantName" type="search" style="width:100%;padding:0.55rem;border:1px solid #bbb;border-radius:4px;">
    </div>
    <div>
      <label for="assignCricclubId" style="display:block;font-weight:600;margin-bottom:0.35rem;">CricClub ID</label>
      <input id="assignCricclubId" type="search" style="width:100%;padding:0.55rem;border:1px solid #bbb;border-radius:4px;">
    </div>
    <div>
      <label for="assignFromDate" style="display:block;font-weight:600;margin-bottom:0.35rem;">As Of / From Date</label>
      <input id="assignFromDate" type="date" style="width:100%;padding:0.55rem;border:1px solid #bbb;border-radius:4px;">
    </div>
  </div>

  <div style="display:flex;gap:0.5rem;flex-wrap:wrap;margin-bottom:1rem;">
    <button id="loadUnassigned" type="button" style="padding:0.6rem 0.85rem;border:0;border-radius:4px;background:#111;color:#fff;">Load Unassigned</button>
    <button id="clearAssignSearch" type="button" style="padding:0.6rem 0.85rem;border:0;border-radius:4px;background:#2563eb;color:#fff;">Clear</button>
  </div>

  <div id="coachStatus" style="font-weight:600;margin-bottom:1rem;"></div>
  <div id="unassignedResults" style="overflow-x:auto;"></div>
</section>

<script>
document.addEventListener("DOMContentLoaded", () => {
  const proxyBase = "https://seal-proxy-secure.onrender.com";
  const coachKey = document.getElementById("coachKey");
  const saveCoachKey = document.getElementById("saveCoachKey");
  const coachKeyStatus = document.getElementById("coachKeyStatus");
  const coachStatus = document.getElementById("coachStatus");
  const assignFromDate = document.getElementById("assignFromDate");
  const assignParticipantName = document.getElementById("assignParticipantName");
  const assignCricclubId = document.getElementById("assignCricclubId");
  const unassignedResults = document.getElementById("unassignedResults");
  let batches = [];
  let participants = [];

  const savedKey = sessionStorage.getItem("sealCoachKey") || sessionStorage.getItem("sealAdminKey") || "";
  if (savedKey) {
    coachKey.value = savedKey;
    coachKeyStatus.textContent = "Key loaded for this browser session.";
  }
  assignFromDate.value = new Date().toISOString().slice(0, 10);

  function getKey() {
    return coachKey.value.trim();
  }

  function requireKey() {
    if (!getKey()) {
      coachStatus.textContent = "Enter the coach key first.";
      return false;
    }
    return true;
  }

  function buildUrl(path, params = {}) {
    const url = new URL(proxyBase + path);
    url.searchParams.set("key", getKey());
    for (const [key, value] of Object.entries(params)) {
      if (value) url.searchParams.set(key, value);
    }
    return url.toString();
  }

  function escapeHtml(value) {
    return String(value || "").replace(/[&<>"']/g, char => ({
      "&": "&amp;",
      "<": "&lt;",
      ">": "&gt;",
      '"': "&quot;",
      "'": "&#39;"
    }[char]));
  }

  function batchLabel(batch) {
    const timeRange = batch.end_time ? `${batch.time}-${batch.end_time}` : batch.time;
    const location = batch.location_name ? `${batch.location_name} - ` : "";
    return `${location}${batch.batch_name} - ${batch.day} ${timeRange}`;
  }

  function batchOptions() {
    return ['<option value="">Select batch</option>'].concat(
      batches.map(batch => `<option value="${batch.batch_id}">${escapeHtml(batchLabel(batch))}</option>`)
    ).join("");
  }

  async function loadBatches() {
    if (batches.length) return;
    const response = await fetch(buildUrl("/coach/batches"));
    const data = await response.json();
    if (!data.success) throw new Error(data.error || "Could not load batches.");
    batches = data.batches || [];
  }

  function selectedBatchIds(index) {
    return [
      document.getElementById(`assignBatch1-${index}`).value,
      document.getElementById(`assignBatch2-${index}`).value
    ].filter(Boolean);
  }

  function renderParticipants() {
    if (!participants.length) {
      unassignedResults.innerHTML = "<p>No unassigned active participants found.</p>";
      return;
    }

    unassignedResults.innerHTML = `
      <table style="width:100%;border-collapse:collapse;">
        <thead>
          <tr style="background:#f3f4f6;">
            <th style="border:1px solid #ddd;padding:0.5rem;text-align:left;">Participant</th>
            <th style="border:1px solid #ddd;padding:0.5rem;text-align:left;">CricClub ID</th>
            <th style="border:1px solid #ddd;padding:0.5rem;text-align:left;">Product</th>
            <th style="border:1px solid #ddd;padding:0.5rem;text-align:left;">Batch Day 1</th>
            <th style="border:1px solid #ddd;padding:0.5rem;text-align:left;">Batch Day 2</th>
            <th style="border:1px solid #ddd;padding:0.5rem;text-align:left;">Action</th>
          </tr>
        </thead>
        <tbody>
          ${participants.map((participant, index) => `
            <tr>
              <td style="border:1px solid #ddd;padding:0.5rem;">${escapeHtml(participant.participant_name)}</td>
              <td style="border:1px solid #ddd;padding:0.5rem;">${escapeHtml(participant.cricclub_id)}</td>
              <td style="border:1px solid #ddd;padding:0.5rem;">${escapeHtml(participant.product_title)}</td>
              <td style="border:1px solid #ddd;padding:0.5rem;"><select id="assignBatch1-${index}" style="width:100%;padding:0.45rem;border:1px solid #bbb;border-radius:4px;">${batchOptions()}</select></td>
              <td style="border:1px solid #ddd;padding:0.5rem;"><select id="assignBatch2-${index}" style="width:100%;padding:0.45rem;border:1px solid #bbb;border-radius:4px;">${batchOptions()}</select></td>
              <td style="border:1px solid #ddd;padding:0.5rem;"><button type="button" data-assign-index="${index}" style="padding:0.5rem 0.75rem;border:0;border-radius:4px;background:#2563eb;color:#fff;">Save</button></td>
            </tr>
          `).join("")}
        </tbody>
      </table>
    `;
  }

  saveCoachKey.addEventListener("click", () => {
    if (!getKey()) {
      coachKeyStatus.textContent = "Enter a key.";
      return;
    }
    sessionStorage.setItem("sealCoachKey", getKey());
    coachKeyStatus.textContent = "Key saved for this browser session.";
  });

  document.getElementById("clearAssignSearch").addEventListener("click", () => {
    assignParticipantName.value = "";
    assignCricclubId.value = "";
    assignFromDate.value = new Date().toISOString().slice(0, 10);
    coachStatus.textContent = "";
    unassignedResults.innerHTML = "";
  });

  document.getElementById("loadUnassigned").addEventListener("click", async () => {
    try {
      if (!requireKey()) return;
      coachStatus.textContent = "Loading unassigned participants...";
      await loadBatches();
      if (!batches.length) {
        coachStatus.textContent = "No batches found. Add batches to the Batches table first.";
        return;
      }
      const response = await fetch(buildUrl("/coach/unassigned-participants", {
        as_of_date: assignFromDate.value,
        participant_name: assignParticipantName.value.trim(),
        cricclub_id: assignCricclubId.value.trim()
      }));
      const data = await response.json();
      if (!data.success) throw new Error(data.error || "Could not load participants.");
      participants = data.participants || [];
      coachStatus.textContent = `Unassigned participants loaded as of ${data.as_of_date || assignFromDate.value}.`;
      renderParticipants();
    } catch (err) {
      coachStatus.textContent = err.message || "Could not load unassigned participants.";
    }
  });

  unassignedResults.addEventListener("click", async event => {
    const button = event.target.closest("[data-assign-index]");
    if (!button) return;

    const index = Number(button.dataset.assignIndex);
    const batchIds = selectedBatchIds(index);
    if (!batchIds.length) {
      coachStatus.textContent = "Select at least one batch.";
      return;
    }

    try {
      const response = await fetch(buildUrl("/coach/batch-assignments"), {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify({
          key: getKey(),
          subscription_id: participants[index].subscription_id,
          batch_ids: batchIds,
          from_date: assignFromDate.value
        })
      });
      const data = await response.json();
      if (!data.success) throw new Error(data.error || "Could not save batch assignment.");
      coachStatus.textContent = "Batch assignment saved.";
      participants.splice(index, 1);
      renderParticipants();
    } catch (err) {
      coachStatus.textContent = err.message || "Could not save batch assignment.";
    }
  });
});
</script>
{% else %}
<section style="max-width:760px;margin:0 auto;padding:2rem;">
  <h1>Access denied</h1>
  <p>You do not have permission to view this page.</p>
</section>
{% endif %}
